@model BookDisplayModel
@{
    // 1. Cấu hình phân trang (Controller đã cung cấp paged Books)
    int pageSize = 15; // consistent with controller
    int currentPage = (int?)(ViewData["CurrentPage"]) ?? 1;
    int totalPages = (int?)(ViewData["TotalPages"]) ?? 1;

    // Step cũ (1,2,3,4) của bạn
    var currentStep = (int?)(ViewData["IteratorStep"]) ?? 1;
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 mb-4 p-2 bg-white border border-primary border-opacity-25">
        <form asp-action="Index" method="get" class="row g-2 align-items-center">
            <div class="col-auto">
                <select class="form-select border-primary fw-bold text-primary" id="step" name="step" onchange="this.form.submit()">
                    @for (int i = 1; i <= 4; i++) { <option value="@i" selected="@(currentStep == i)">@i</option> }
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select border-primary fw-bold" id="genreId" name="genreId" onchange="this.form.submit()">
                    <option value="0">Tất cả thể loại</option>
                    @foreach (var genre in Model.Genres) { <option value="@genre.Id" selected="@(genre.Id == Model.GenreId)">@genre.GenreName</option> }
                </select>
            </div>
            <div class="col-md-7">
                <div class="input-group">
                    <input type="text" class="form-control border-primary fw-bold" value="@Model.STerm" id="sterm" name="sterm" placeholder="Tìm tên sách...">
                    <button type="submit" class="btn btn-primary px-4 fw-bold">Tìm kiếm</button>
                    <a href="/Home/Index" class="btn btn-outline-danger fw-bold">Làm mới</a>
                    
                </div>
            </div>
        </form>
    </div>

    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-4 mb-5">
        @foreach (var book in Model.Books)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 border-bottom border-primary border-3 transition-hover">
                    <div class="position-relative">
                        <img style="height:200px; object-fit:cover;" 
                             src="@(string.IsNullOrEmpty(book.Image) ? "/images/NoImage.png" : "/images/" + book.Image)" 
                             class="card-img-top p-2 rounded" alt="@book.BookName">
                    </div>

                    <div class="card-body d-flex flex-column p-3">
                        <h5 class="card-title fw-bold mb-1" style="height: 3.2rem; line-height: 1.6rem; overflow: hidden;">
                            <a asp-controller="Book" asp-action="Details" asp-route-id="@book.Id" class="text-decoration-none text-black hover-blue">@book.BookName</a>
                        </h5>
                        
                        <div class="mb-2">
                            <div class="text-black fs-6" style="line-height: 1.2rem;"><strong>Thể loại:</strong> @book.GenreName</div>
                            <div class="text-black fs-6" style="line-height: 1.2rem;"><strong>Tác giả:</strong> @book.AuthorName</div>
                        </div>
                        
                        <div class="text-success fw-bold fs-5 mb-3"><strong>Giá:</strong> @book.Price.ToString("N0") đ</div>

                        <div class="mt-auto text-center">
                            @if (book.Quantity > 0) {
                                <button type="button" onclick="add(@book.Id)" class="btn btn-primary w-100 fw-bold shadow-sm py-2">Thêm vào giỏ</button>
                            } else {
                                <button type="button" class="btn btn-secondary w-100 disabled text-white" disabled>Hết hàng</button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-5 pb-5">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(currentPage == i ? "active" : "")">
                        <a class="page-link custom-page-link shadow-sm" href="?page=@i&genreId=@Model.GenreId&sterm=@Model.STerm&step=@currentStep">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

<style>
    .text-black { color: #000000 !important; }
    .custom-page-link {
        background-color: #0d6efd !important;
        color: white !important;
        border: 1px solid #ffffff44;
        margin: 0 5px;
        border-radius: 8px !important;
        min-width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
    }
    .page-item.active .custom-page-link { 
        background-color: #0551bb !important; 
        border: 2px solid #fff;
        transform: scale(1.1);
    }
    .hover-blue:hover { color: #0d6efd !important; }
    .transition-hover:hover { transform: translateY(-8px); transition: 0.3s; box-shadow: 0 15px 30px rgba(0,0,0,0.15) !important; }
</style>

@section Scripts {
    <script>
        async function add(bookId) {
            var usernameEl = document.getElementById("username");
            if(usernameEl == null) { window.location.href = "/Identity/Account/Login"; return; }
            try {
                var response = await fetch(`/Cart/AddItem?bookId=${bookId}`);
                if (response.status == 200) {
                    var result = await response.json();
                    var cartCountEl = document.getElementById("cartCount");
                    if(cartCountEl) cartCountEl.innerHTML = result;
                   showToast("Đã thêm vào giỏ!");
                }
            } catch (err) { console.log(err); }
        }
    </script>
}