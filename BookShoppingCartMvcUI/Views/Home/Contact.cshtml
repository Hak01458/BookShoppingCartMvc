@model BookShoppingCartMvcUI.Models.ViewModels.ContactFormViewModel
@{
    ViewData["Title"] = "Liên hệ";
}

<div class="contact-page py-5">
    <div class="contact-hero rounded-4 p-4 p-md-5 mb-5 text-center shadow-sm">
        <h1 class="hero-title fw-bold mb-3 text-primary">Liên hệ với chúng tôi</h1>
        <p class="hero-subtitle mb-4 text-dark opacity-75">Chúng tôi luôn sẵn sàng lắng nghe và hỗ trợ bạn 24/7</p>
        <div class="hero-line mx-auto bg-primary"></div>
    </div>

    <div class="row g-4 g-lg-5">
        <div class="col-lg-5">
            <h2 class="fw-bold mb-3 text-dark">Thông tin liên hệ</h2>
            <p class="text-secondary mb-4">Đội ngũ hỗ trợ của chúng tôi sẽ phản hồi bạn trong vòng 24 giờ làm việc.</p>

            <div class="contact-card d-flex gap-3 p-4 mb-3 shadow-sm border rounded-4">
                <div class="icon-box bg-primary text-white rounded-3 shadow-sm">
                    <i class="bi bi-geo-alt-fill fs-4"></i>
                </div>
                <div>
                    <h5 class="mb-1 fw-bold text-dark">Địa chỉ</h5>
                    <p class="mb-0 text-muted">806 Lê Quang Đạo, Trung Mỹ Tây, Quận 12</p>
                    <p class="mb-0 text-muted">Thành phố Hồ Chí Minh, Việt Nam</p>
                </div>
            </div>

            <div class="contact-card d-flex gap-3 p-4 mb-3 shadow-sm border rounded-4">
                <div class="icon-box bg-primary text-white rounded-3 shadow-sm">
                    <i class="bi bi-telephone-fill fs-4"></i>
                </div>
                <div>
                    <h5 class="mb-1 fw-bold text-dark">Điện thoại</h5>
                    <p class="mb-0 text-muted">+84 355 855 155</p>
                    <p class="mb-0 text-muted">+84 988 899 899</p>
                </div>
            </div>

            <div class="contact-card d-flex gap-3 p-4 mb-3 shadow-sm border rounded-4">
                <div class="icon-box bg-primary text-white rounded-3 shadow-sm">
                    <i class="bi bi-envelope-fill fs-4"></i>
                </div>
                <div>
                    <h5 class="mb-1 fw-bold text-dark">Email</h5>
                    <p class="mb-0 text-muted">info@EBookStore.vn</p>
                    <p class="mb-0 text-muted">support@EBookStore.vn</p>
                </div>
            </div>

            <div class="mt-4">
                <h5 class="fw-bold mb-3 text-dark">Theo dõi chúng tôi</h5>
                <div class="d-flex gap-2">
                    <a href="#" class="social-btn btn btn-outline-primary rounded-circle"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="social-btn btn btn-outline-primary rounded-circle"><i class="bi bi-instagram"></i></a>
                    <a href="#" class="social-btn btn btn-outline-primary rounded-circle"><i class="bi bi-twitter"></i></a>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="form-panel rounded-4 p-4 p-md-5 shadow border bg-white">
                <h2 class="fw-bold mb-4 text-primary">Gửi tin nhắn cho EBookStore</h2>

                @if (TempData["ContactSuccess"] != null)
                {
                    <div class="alert alert-success d-flex align-items-center mb-4 shadow-sm" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        <div>@TempData["ContactSuccess"]</div>
                    </div>
                }

                <form method="post" asp-action="IndexContact" asp-controller="Home">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label fw-bold text-dark">Họ và tên *</label>
                            <input asp-for="Name" class="form-control border-primary border-opacity-25 py-2" placeholder="Nguyễn Văn A" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label fw-bold text-dark">Số điện thoại</label>
                            <input asp-for="Phone" class="form-control border-primary border-opacity-25 py-2" placeholder="0901234xxx" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-bold text-dark">Email liên hệ *</label>
                        <input asp-for="Email" class="form-control border-primary border-opacity-25 py-2" placeholder="email@example.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Subject" class="form-label fw-bold text-dark">Chủ đề cần hỗ trợ</label>
                        <select asp-for="Subject" class="form-select border-primary border-opacity-25 py-2">
                            <option value="">-- Chọn chủ đề --</option>
                            <option value="Hỗ trợ kỹ thuật">Hỗ trợ kỹ thuật</option>
                            <option value="Vấn đề đơn hàng">Vấn đề đơn hàng</option>
                            <option value="Hợp tác kinh doanh">Hợp tác kinh doanh</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Message" class="form-label fw-bold text-dark">Nội dung tin nhắn *</label>
                        <textarea asp-for="Message" class="form-control border-primary border-opacity-25" rows="5" placeholder="Bạn cần chúng tôi giúp gì?"></textarea>
                        <span asp-validation-for="Message" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold fs-5 shadow">
                        Gửi tin nhắn ngay <i class="bi bi-send ms-2"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="mt-5">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden position-relative">
            <div class="bg-primary text-white p-3 text-center">
                <h4 class="mb-0 fw-bold"><i class="bi bi-map me-2"></i>Vị trí cửa hàng EBookStore</h4>
            </div>
            <div class="map-frame-wrapper position-relative">
                <iframe 
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3918.473551525287!2d106.61962387586548!3d10.851532157799507!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752a1926678255%3A0xc6f3f054593450e1!2zODA2IEzDqiBRdWFuZyDEkOG6oW8sIFRydW5nIE3hu7kgVMOieSwgUXXhuq1uIDEyLCBI4buTIENow60gTWluaCwgVmnhu4d0IE5hbQ!5e0!3m2!1svi!2s!4v1715678901234!5m2!1svi!2s" 
                    width="100%" 
                    height="450" 
                    style="border:0; display:block;" 
                    allowfullscreen="" 
                    loading="lazy" 
                    referrerpolicy="no-referrer-when-downgrade">
                </iframe>

                <!-- map pin overlay removed -->
            </div>
        </div>
    </div>
</div>

<style>
    .contact-hero {
        background-color: #f0f7ff;
        border: 1px solid #dee2e6;
    }
    .hero-line {
        width: 80px;
        height: 5px;
        border-radius: 10px;
        background-color: #0d6efd; /* ensure blue */
    }
    .icon-box {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .contact-card {
        background: #fff;
        transition: all 0.3s ease;
    }
    .contact-card:hover {
        transform: translateX(10px);
        border-color: #0d6efd !important;
    }
    .social-btn {
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .form-panel {
        background-color: #ffffff;
    }
    .form-control:focus, .form-select:focus {
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
        border-color: #0d6efd;
    }
    .map-frame-wrapper { position: relative; }
    .send-btn { background-color: #0d6efd; border-color: #0d6efd; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}