@model BookDTO
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Cập nhật sách";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" asp-controller="Book" class="btn btn-outline-secondary me-3 shadow-sm">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
        <h2 class="text-primary fw-bold mb-0 text-uppercase">Cập nhật thông tin sách</h2>
    </div>

    @if (TempData["errorMessage"] != null)
    {
        <div class="alert alert-danger shadow-sm mb-3">
            <i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["errorMessage"]
        </div>
    }

    <div class="row">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow-sm border-0 border-top border-primary border-4">
                <div class="card-body p-4 p-md-5">
                    <form asp-action="UpdateBook" enctype="multipart/form-data" method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="Image" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-black">Tên sách *</label>
                            <input type="text" class="form-control border-primary border-opacity-25 py-2 fw-semibold" asp-for="BookName" />
                            <span asp-validation-for="BookName" class="text-danger small"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-black">Tác giả *</label>
                                <input type="text" class="form-control border-primary border-opacity-25 py-2" asp-for="AuthorName" />
                                <span asp-validation-for="AuthorName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-black">Giá bán (VNĐ) *</label>
                                <input type="number" class="form-control border-primary border-opacity-25 py-2 fw-bold text-primary" asp-for="Price" />
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-black">Thể loại *</label>
                            <select class="form-select border-primary border-opacity-25 py-2 fw-semibold" asp-for="GenreId" asp-items="Model.GenreList">
                                <option value="">-- Chọn thể loại --</option>
                            </select>
                            <span asp-validation-for="GenreId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4 p-3 bg-light rounded-3 border">
                            <label class="form-label fw-bold text-black d-block mb-3">Hình ảnh sản phẩm</label>
                            <div class="d-flex align-items-center gap-4">
                                @if (!string.IsNullOrEmpty(Model.Image))
                                {
                                    <div class="text-center">
                                        <img src="/images/@Model.Image" class="rounded shadow-sm border" style="width:100px; height:130px; object-fit:cover" />
                                        <div class="small text-muted mt-1">Ảnh hiện tại</div>
                                    </div>
                                }
                                <div class="flex-grow-1">
                                    <label class="small text-secondary mb-1">Thay đổi ảnh mới:</label>
                                    <input type="file" class="form-control border-primary border-opacity-25" asp-for="ImageFile" />
                                </div>
                            </div>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold shadow">
                                <i class="bi bi-cloud-arrow-up-fill me-2"></i> LƯU THAY ĐỔI
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4 col-lg-5">
            <div class="alert alert-info border-0 shadow-sm p-4">
                <h5 class="fw-bold"><i class="bi bi-info-circle-fill me-2"></i>Hướng dẫn cập nhật</h5>
                <hr>
                <ul class="mb-0 ps-3">
                    <li class="mb-2">Kiểm tra kỹ <strong>Tên sách</strong> và <strong>Giá tiền</strong> trước khi lưu.</li>
                    <li class="mb-2">Nếu không muốn thay đổi hình ảnh, hãy để trống ô chọn tệp.</li>
                    <li>Thông tin sẽ được cập nhật ngay lập tức trên trang chủ sau khi bạn nhấn lưu.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    .text-black { color: #000000 !important; }
    .form-control:focus, .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }
</style>