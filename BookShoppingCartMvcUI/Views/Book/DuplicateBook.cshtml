@model BookDTO
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Nhân bản sách";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" asp-controller="Book" class="btn btn-outline-secondary me-3 shadow-sm">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
        <h2 class="text-primary fw-bold mb-0 text-uppercase">Nhân bản thông tin sách</h2>
    </div>

    <div class="row">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow-sm border-0 border-top border-warning border-4">
                <div class="card-body p-4 p-md-5">
                    <div class="alert alert-warning border-0 shadow-sm mb-4">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong class="fs-5">Xác nhận nhân bản?</strong>
                        <p class="mb-0 small">Hệ thống sẽ tạo ra một bản sao mới dựa trên thông tin dưới đây.</p>
                    </div>

                    <form asp-action="DuplicateBookConfirm" enctype="multipart/form-data" method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="Image" />

                        <div class="mb-3">
                            <label class="form-label fw-bold text-black">Tên sách mới *</label>
                            <input type="text" class="form-control border-warning border-opacity-25 py-2 fw-semibold" asp-for="BookName" placeholder="Nhập tên cho bản sao..." />
                            <span asp-validation-for="BookName" class="text-danger small"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-black">Tác giả *</label>
                                <input type="text" class="form-control border-warning border-opacity-25 py-2" asp-for="AuthorName" />
                                <span asp-validation-for="AuthorName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-black">Giá bán (VNĐ) *</label>
                                <input type="number" class="form-control border-warning border-opacity-25 py-2 fw-bold text-primary" asp-for="Price" />
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-black">Thể loại *</label>
                            <select class="form-select border-warning border-opacity-25 py-2 fw-semibold" asp-for="GenreId" asp-items="Model.GenreList">
                                <option value="">-- Chọn thể loại --</option>
                            </select>
                            <span asp-validation-for="GenreId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4 p-3 bg-light rounded-3 border">
                            <label class="form-label fw-bold text-black d-block mb-3">Hình ảnh bản sao</label>
                            <div class="d-flex align-items-center gap-4">
                                @if (!string.IsNullOrEmpty(Model.Image))
                                {
                                    <div class="text-center">
                                        <img src="/images/@Model.Image" class="rounded shadow-sm border" style="width:100px; height:130px; object-fit:cover" />
                                        <div class="small text-muted mt-1">Ảnh gốc</div>
                                    </div>
                                }
                                <div class="flex-grow-1">
                                    <label class="small text-secondary mb-1">Tải ảnh khác (nếu muốn):</label>
                                    <input type="file" class="form-control border-warning border-opacity-25" asp-for="ImageFile" />
                                </div>
                            </div>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-warning btn-lg fw-bold shadow text-dark">
                                <i class="bi bi-copy me-2"></i> XÁC NHẬN NHÂN BẢN
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4 col-lg-5">
            <div class="card bg-white border-0 shadow-sm p-4">
                <h5 class="fw-bold text-warning"><i class="bi bi-info-square-fill me-2"></i>Thông tin nhân bản</h5>
                <hr>
                <p class="text-dark small">Việc nhân bản giúp bạn nhanh chóng tạo ra sản phẩm tương tự mà không cần nhập lại từ đầu.</p>
                <ul class="small text-muted ps-3">
                    <li>Bạn nên đổi tên sách để tránh trùng lặp hoàn toàn.</li>
                    <li>Giá tiền và thể loại có thể chỉnh sửa ngay tại đây.</li>
                    <li>Ảnh gốc sẽ được giữ nguyên nếu bạn không chọn tệp mới.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    .text-black { color: #000000 !important; }
    .form-control:focus, .form-select:focus {
        border-color: #ffc107;
        box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.15);
    }
</style>