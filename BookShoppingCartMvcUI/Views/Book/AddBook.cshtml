@model BookDTO
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm sách mới";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" asp-controller="Book" class="btn btn-outline-secondary me-3 shadow-sm">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
        <h2 class="text-primary fw-bold mb-0 text-uppercase">Thêm sách vào hệ thống</h2>
    </div>

    <div class="row">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0 border-top border-primary border-4">
                <div class="card-body p-4 p-md-5">
                    <form asp-action="AddBook" enctype="multipart/form-data" method="post">
                        @* <input type="hidden" asp-for="Id" /> *@

                        <div class="mb-3">
                            <label class="form-label fw-bold text-black">Tên sách *</label>
                            <input type="text" class="form-control border-primary border-opacity-25 py-2 fw-semibold" asp-for="BookName" placeholder="Nhập tên sách..." />
                            <span asp-validation-for="BookName" class="text-danger small"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-black">Tác giả *</label>
                                <input type="text" class="form-control border-primary border-opacity-25 py-2" asp-for="AuthorName" placeholder="Tên tác giả" />
                                <span asp-validation-for="AuthorName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-black">Giá bán (VNĐ) *</label>
                                <input type="number" class="form-control border-primary border-opacity-25 py-2 fw-bold text-primary" asp-for="Price" placeholder="0" />
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-black">Thể loại *</label>
                            <select class="form-select border-primary border-opacity-25 py-2 fw-semibold" asp-for="GenreId" asp-items="Model.GenreList">
                                <option value="">-- Chọn thể loại sách --</option>
                            </select>
                            <span asp-validation-for="GenreId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-black">Hình ảnh bìa sách</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-image text-primary"></i></span>
                                <input type="file" class="form-control border-primary border-opacity-25 py-2" asp-for="ImageFile" />
                            </div>
                            <div class="form-text text-muted">Hỗ trợ các định dạng: .jpg, .png, .jpeg</div>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold shadow">
                                <i class="bi bi-plus-circle me-2"></i>XÁC NHẬN THÊM SÁCH
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        
        <div class="col-md-4 col-lg-3">
            <div class="card bg-light border-0 shadow-sm p-3">
                <h5 class="fw-bold text-primary border-bottom pb-2 mb-3">Lưu ý khi thêm</h5>
                <ul class="small text-dark ps-3">
                    <li class="mb-2">Các trường có dấu <b>*</b> là bắt buộc.</li>
                    <li class="mb-2">Nên chọn ảnh có kích thước đứng (3:4) để hiển thị đẹp nhất.</li>
                    <li>Giá sách nên nhập số nguyên dương.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    .text-black {
        color: #000000 !important;
    }
    
    .form-control:focus, .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }
</style>

@* Nếu Layout của bạn đã có RenderSection("Scripts"), bạn có thể bỏ comment đoạn dưới *@
