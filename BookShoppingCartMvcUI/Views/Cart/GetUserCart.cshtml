@model ShoppingCart
@{
    ViewData["Title"] = "Giỏ hàng của tôi";
}

<div style="width:95%;margin:auto" class="mt-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Giỏ hàng</li>
        </ol>
    </nav>

    @if (Model != null && Model.CartDetails != null && Model.CartDetails.Count > 0)
    {
        <h4 class="text-primary fw-bold mb-4"><i class="bi bi-cart3 me-2"></i>GIỎ HÀNG CỦA BẠN</h4>

        <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-primary text-white" style="font-size: 1.15rem;">
                        <tr>
                            <th class="ps-4 py-3 border-0">Sách</th>
                            <th class="border-0">Hình ảnh</th>
                            <th class="border-0">Thể loại</th>
                            <th class="border-0">Đơn giá</th>
                            <th class="border-0">Thành tiền</th>
                            <th class="text-center border-0 pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.CartDetails)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-black" style="font-size: 1.1rem;">@item.Book.BookName</td>
                                <td class="py-2">
                                    <img src="@(string.IsNullOrEmpty(item.Book.Image) ? "/images/NoImage.png" : "/images/" + item.Book.Image)" 
                                         style="width:80px;height:110px;object-fit:cover" class="rounded shadow-sm" />
                                </td>
                                <td><span class="badge rounded-pill bg-info text-white px-3 py-2">@item.Book.Genre.GenreName</span></td>
                                <td class="text-black">
                                    <div class="fw-bold">@item.Book.Price.ToString("N0") đ</div>
                                </td>
                                <td class="fw-bold text-primary" style="font-size: 1.2rem;">@((item.Book.Price * item.Quantity).ToString("N0")) đ</td>
                                <td class="text-center pe-4">
                                    <div class="d-flex justify-content-center align-items-center gap-2">
                                        <a class="btn btn-outline-primary fw-bold btn-wide" href="/cart/removeitem?bookid=@item.BookId">-</a>
                                        
                                        <span class="mx-2 fw-bold fs-5 text-black">@item.Quantity</span>

                                        @if (item.Quantity < item.Book.Stock.Quantity)
                                        {
                                            <a class="btn btn-outline-primary fw-bold btn-wide" href="/Cart/AddItem?bookId=@item.BookId&&redirect=1">+</a>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger text-white py-2 px-3 small">HẾT HÀNG</span>
                                        }

                                        <form method="get" action="/Cart/Duplicate" style="display:inline-block;margin:0;">
                                            <input type="hidden" name="bookId" value="@item.BookId" />
                                            <input type="hidden" name="qty" value="@item.Quantity" />
                                            <button type="submit" class="btn btn-secondary ms-3 px-3 shadow-sm" title="Nhân đôi số lượng">
                                                <i class="bi bi-files"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="row mt-5 pt-3 border-top">
            <div class="col-md-6">
                <a class="btn btn-outline-secondary px-4 py-2 fw-bold" href="/">
                    <i class="bi bi-arrow-left me-2"></i> Tiếp tục mua sắm
                </a>
            </div>
            
            <div class="col-md-6 text-end">
                <div class="mb-3">
                    <div class="d-inline-block p-3 border rounded bg-light shadow-sm" style="min-width: 300px;">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-black fw-bold me-4">TỔNG TIỀN:</span> 
                            <span class="text-primary fw-bolder fs-3">
                                @((Model.CartDetails.Sum(item => item.Book.Price * item.Quantity)).ToString("N0")) đ
                            </span>
                        </div>
                    </div>
                </div>

                <div>
                    <a class="btn btn-primary px-5 py-2 fw-bold shadow text-uppercase" href="/Cart/Checkout" style="font-size: 1.1rem;">
                        Thanh toán ngay <i class="bi bi-credit-card-2-back ms-2"></i>
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 shadow-sm rounded-3 bg-white border">
            <i class="bi bi-cart-x text-primary opacity-25" style="font-size: 5rem;"></i>
            <h4 class="mt-3 text-black fw-bold">Giỏ hàng trống</h4>
            <a href="/" class="btn btn-primary px-4 mt-3">Quay lại cửa hàng</a>
        </div>
    }
</div>

<style>
    .text-black { color: #000000 !important; }
    
    .table thead th {
        color: #ffffff !important;
        font-weight: 700;
        vertical-align: middle;
    }

    /* Đã điều chỉnh chiều rộng nút tăng giảm ngắn lại */
    .btn-wide {
        min-width: 45px; 
        height: 35px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.2s;
    }
    
    .btn-wide:hover {
        background-color: #0d6efd !important;
        color: white !important;
    }

    .badge.bg-info { background-color: #0dcaf0 !important; color: white !important; }
    .badge.bg-danger { background-color: #dc3545 !important; color: white !important; }

    .table-hover tbody tr:hover {
        background-color: #f8faff;
    }
</style>