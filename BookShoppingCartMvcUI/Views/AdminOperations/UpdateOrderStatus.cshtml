@model UpdateOrderStatusModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Cập nhật trạng thái";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex align-items-center mb-4">
        <a class="btn btn-outline-secondary me-3 shadow-sm" asp-action="AllOrders">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
        <h2 class="text-primary fw-bold mb-0">CẬP NHẬT TRẠNG THÁI ĐƠN HÀNG</h2>
    </div>

    <div class="row">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 border-top border-primary border-4">
                <div class="card-body p-4">
                    <form asp-action="UpdateOrderStatus" method="post">
                        <input type="hidden" asp-for="OrderId" />

                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark fs-5">Chọn trạng thái mới</label>
                            <div class="input-group">
                                <span class="input-group-text bg-primary text-white border-primary">
                                    <i class="bi bi-gear-wide-connected"></i>
                                </span>
                                <select class="form-select border-primary border-opacity-25 py-2 fw-semibold" 
                                        asp-for="OrderStatusId" 
                                        asp-items="@Model.OrderStatusList">
                                    <option value="">-- Chọn trạng thái đơn hàng --</option>
                                </select>
                            </div>
                            <span class="text-danger small" asp-validation-for="OrderStatusId"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm">
                                <i class="bi bi-check-circle me-1"></i> CẬP NHẬT NGAY
                            </button>
                        </div>

                        @if (TempData["msg"] != null)
                        {
                            <div class="alert alert-info mt-4 d-flex align-items-center shadow-sm" role="alert">
                                <i class="bi bi-info-circle-fill me-2"></i>
                                <div>@TempData["msg"]</div>
                            </div>
                        }
                    </form>
                </div>
            </div>
            
            <div class="mt-4 p-3 bg-light rounded-3 border border-info border-opacity-25">
                <p class="small text-muted mb-0">
                    <i class="bi bi-lightbulb me-1"></i> 
                    <strong>Lưu ý:</strong> Việc thay đổi trạng thái sẽ giúp khách hàng theo dõi được tiến trình của đơn hàng trong mục "Đơn hàng của tôi".
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }
    .btn-lg {
        font-size: 1.1rem;
        letter-spacing: 0.5px;
    }
</style>
