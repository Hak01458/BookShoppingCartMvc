@model IEnumerable<Order>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div style="width:100%" class="mt-4 px-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold"><i class="bi bi-box-seam me-2"></i>DANH SÁCH ĐƠN HÀNG</h2>
        <span class="badge bg-secondary">Tổng cộng: @(Model?.Count() ?? 0) đơn hàng</span>
    </div>

    @if (Model != null && Model.Count() > 0)
    {
        <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-primary text-white" style="font-size: 1.1rem;">
                        <tr>
                            <th class="ps-3 py-3">Ngày đặt</th>
                            <th>Khách hàng</th>
                            <th>Điện thoại</th>
                            <th>Địa chỉ</th>
                            <th>Thanh toán</th>
                            <th>Trạng thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="text-dark" style="font-size: 1.05rem;">
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="ps-3">@order.CreateDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <div class="fw-bold">@order.Name</div>
                                    <small class="text-muted">@order.Email</small>
                                </td>
                                <td>@order.MobileNumber</td>
                                <td style="max-width: 200px;" class="text-truncate" title="@order.Address">@order.Address</td>
                                <td>
                                    <div class="small fw-bold text-uppercase mb-1">@order.PaymentMethod</div>
                                    @if (order.IsPaid)
                                    {
                                        <span class="badge bg-success text-white"><i class="bi bi-check-circle me-1"></i>Đã trả tiền</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger text-white"><i class="bi bi-x-circle me-1"></i>Chưa trả tiền</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-info text-dark fw-bold p-2">@order.OrderStatus.StatusName</span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <button type="button" data-bs-toggle="modal" data-bs-target="#modal-@order.Id" class="btn btn-sm btn-primary shadow-sm px-3">
                                            <i class="bi bi-eye me-1"></i> Chi tiết
                                        </button>
                                        
                                        <a asp-action="UpdateOrderStatus" asp-route-orderId="@order.Id" class="btn btn-sm btn-outline-primary px-2" title="Cập nhật trạng thái">
                                            <i class="bi bi-arrow-repeat"></i> Trạng thái
                                        </a>
                                        
                                        <a asp-action="TogglePaymentStatus" asp-route-orderId="@order.Id" class="btn btn-sm btn-outline-info px-2" title="Đổi trạng thái thanh toán">
                                            <i class="bi bi-currency-exchange"></i>
                                        </a>
                                    </div>

                                    @* Partial view Modal chi tiết *@
                                    @await Html.PartialAsync("/Views/AdminOperations/_OrderDetailModal.cshtml", new OrderDetailModalDTO { DivId = order.Id.ToString(), OrderDetail = order.OrderDetail })
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-light rounded-3 border">
            <i class="bi bi-clipboard-x text-muted" style="font-size: 4rem;"></i>
            <h5 class="mt-3 text-secondary">Hiện chưa có đơn hàng nào trong hệ thống.</h5>
        </div>
    }
</div>

<style>
    /* Ép tiêu đề bảng chữ trắng */
    .table thead th {
        color: #ffffff !important;
        font-weight: 600;
        border: none;
        vertical-align: middle;
    }

    .table tbody tr:hover {
        background-color: #f8faff;
    }

    .badge {
        font-size: 0.85rem;
        letter-spacing: 0.3px;
    }

    .btn-sm {
        font-weight: 500;
    }
</style>`