@model StockDTO
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Cập nhật kho hàng";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" asp-controller="Stock" class="btn btn-outline-secondary me-3 shadow-sm">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
        <h2 class="text-primary fw-bold mb-0 text-uppercase">Cập nhật số lượng kho</h2>
    </div>

    <div class="row">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm border-0 border-top border-primary border-4">
                <div class="card-body p-4">
                    <form asp-action="ManangeStock" method="post">
                        <input type="hidden" asp-for="BookId" />

                        <div class="mb-4">
                            <label class="form-label fw-bold text-black fs-5">Số lượng tồn kho hiện tại</label>
                            <div class="input-group">
                                <span class="input-group-text bg-primary text-white">
                                    <i class="bi bi-box-seam"></i>
                                </span>
                                <input type="number" class="form-control border-primary border-opacity-25 fw-bold fs-5 py-2"
                                       asp-for="Quantity" placeholder="0" />
                            </div>
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm">
                                <i class="bi bi-save me-2"></i>LƯU THAY ĐỔI
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="mt-4 p-3 bg-light rounded-3 border border-warning border-opacity-25">
                <p class="small text-muted mb-0">
                    <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
                    <strong>Lưu ý:</strong> Số lượng nhập vào sẽ là số lượng tồn kho chính xác hiện có trong cửa hàng.
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .text-black {
        color: #000000 !important;
    }
    
    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }

    .input-group-text {
        border-color: rgba(13, 110, 253, 0.25);
    }
</style>