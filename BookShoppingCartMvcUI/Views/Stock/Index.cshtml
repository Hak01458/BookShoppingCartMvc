@model IEnumerable<StockDisplayModel>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý kho hàng";
}

<div class="container-fluid mt-4 px-4">
    <h2 class="text-primary fw-bold mb-4"><i class="bi bi-box-seam me-2"></i>QUẢN LÝ KHO HÀNG</h2>

    <div class="card shadow-sm border-0 mb-4 p-3 bg-light">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <div class="input-group w-50">
                <span class="input-group-text bg-white border-primary border-opacity-25 text-primary">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" name="sTerm" class="form-control border-primary border-opacity-25 fw-bold" placeholder="Nhập tên sách cần tìm..." />
            </div>
            <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">Tìm kiếm</button>
            <a asp-action="Index" asp-controller="Stock" class="btn btn-outline-secondary px-4 shadow-sm">Làm mới</a>
        </form>
    </div>

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-primary text-white" style="font-size: 1.15rem;">
                    <tr>
                        <th class="ps-4 py-3 border-0">Tên sách</th>
                        <th class="border-0">Số lượng tồn</th>
                        <th class="text-center border-0 pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody style="font-size: 1.1rem;">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-black">@item.BookName</td>
                            <td class="fw-bold">
                                @if (item.Quantity <= 5)
                                {
                                    <span class="text-danger"><i class="bi bi-exclamation-triangle-fill me-1"></i>@item.Quantity (Sắp hết)</span>
                                }
                                else
                                {
                                    <span class="text-success">@item.Quantity</span>
                                }
                            </td>
                            <td class="text-center pe-4">
                                <a asp-action="ManangeStock" asp-controller="Stock" asp-route-bookId="@item.BookId" class="btn btn-sm btn-primary px-3 shadow-sm">
                                    <i class="bi bi-pencil-square me-1"></i> Cập nhật kho
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Ép màu đen cho text nội dung */
    .text-black {
        color: #000000 !important;
    }

    /* Tiêu đề bảng chữ trắng */
    .table thead th {
        color: #ffffff !important;
        font-weight: 700;
        vertical-align: middle;
    }

    .table tbody tr:hover {
        background-color: #f8faff;
    }
</style>