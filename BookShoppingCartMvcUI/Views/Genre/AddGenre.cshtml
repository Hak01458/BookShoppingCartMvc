@model GenreDTO
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm thể loại mới";
}

<div class="container-fluid mt-4 px-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" asp-controller="Genre" class="btn btn-outline-secondary me-3 shadow-sm">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
        <h2 class="text-primary fw-bold mb-0 text-uppercase">Thêm thể loại sách</h2>
    </div>

    <div class="row">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 border-top border-primary border-4">
                <div class="card-body p-4 p-md-5">
                    <form asp-action="AddGenre" method="post">
                        @* <input type="hidden" asp-for="Id" /> *@

                        <div class="mb-4">
                            <label class="form-label fw-bold text-black fs-5">Tên thể loại *</label>
                            <div class="input-group">
                                <span class="input-group-text bg-primary text-white border-primary">
                                    <i class="bi bi-tag-fill"></i>
                                </span>
                                <input type="text" class="form-control border-primary border-opacity-25 py-2 fw-semibold"
                                       asp-for="GenreName" placeholder="Ví dụ: Văn học, Kinh tế..." />
                            </div>
                            <span asp-validation-for="GenreName" class="text-danger small"></span>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold shadow">
                                <i class="bi bi-plus-circle me-2"></i>XÁC NHẬN THÊM
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="mt-4 p-3 bg-light rounded-3 border border-info border-opacity-25">
                <p class="small text-muted mb-0">
                    <i class="bi bi-info-circle-fill text-primary me-1"></i>
                    <strong>Mẹo:</strong> Hãy đặt tên thể loại ngắn gọn và rõ ràng để khách hàng dễ dàng tìm kiếm sách trên trang chủ.
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .text-black {
        color: #000000 !important;
    }
    
    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }

    .input-group-text {
        border-right: none;
    }
</style>