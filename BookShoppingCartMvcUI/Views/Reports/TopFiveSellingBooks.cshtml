@model TopNSoldBooksVm
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Sách bán chạy";
}

<div class="container-fluid mt-4 px-4">
    <h2 class="text-primary fw-bold mb-4 text-uppercase">
        <i class="bi bi-graph-up-arrow me-2"></i>Thống kê sách bán chạy
    </h2>

    @if (Model != null)
    {
        <div class="card shadow-sm border-0 mb-4 p-3 bg-light">
            <form class="d-flex align-items-end gap-3" asp-action="TopFiveSellingBooks" method="get">
                <div>
                    <label class="small fw-bold text-dark mb-1">Từ ngày:</label>
                    <input type="date" class="form-control border-primary border-opacity-25 fw-bold" name="sDate" />
                </div>
                <div>
                    <label class="small fw-bold text-dark mb-1">Đến ngày:</label>
                    <input type="date" class="form-control border-primary border-opacity-25 fw-bold" name="eDate" />
                </div>
                <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">
                    <i class="bi bi-funnel-fill me-1"></i> Lọc dữ liệu
                </button>
                <a class="btn btn-outline-secondary px-4 shadow-sm fw-bold" href="/Reports/TopFiveSellingBooks">Làm mới</a>
            </form>
        </div>

        <div class="alert alert-info border-0 shadow-sm mb-4 d-inline-block p-3">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-calendar-range me-2"></i>
                Kết quả từ: <span class="text-primary">@Model.StartDate.ToString("dd/MM/yyyy")</span>
                đến <span class="text-primary">@Model.EndDate.ToString("dd/MM/yyyy")</span>
            </h5>
        </div>

        @if (Model.TopNSoldBooks.Count() == 0)
        {
            <div class="text-center py-5 bg-white border rounded-3 shadow-sm">
                <i class="bi bi-clipboard-x text-muted opacity-25" style="font-size: 4rem;"></i>
                <h4 class="mt-3 text-secondary fw-bold">Không tìm thấy dữ liệu bán hàng</h4>
                <p class="text-muted">Vui lòng chọn khoảng thời gian khác để xem kết quả.</p>
            </div>
        }
        else
        {
            <div class="card shadow-sm border-0 rounded-3 overflow-hidden" style="max-width: 800px;">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-primary text-white" style="font-size: 1.15rem;">
                            <tr>
                                <th class="ps-4 py-3 border-0">Thông tin sách</th>
                                <th class="text-center border-0 pe-4" style="width: 200px;">Số lượng đã bán</th>
                            </tr>
                        </thead>
                        <tbody style="font-size: 1.1rem;">
                            @foreach (var item in Model.TopNSoldBooks)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold text-black">@item.BookName</div>
                                        <small class="text-muted">Tác giả: @item.AuthorName</small>
                                    </td>
                                    <td class="text-center pe-4">
                                        <span class="badge rounded-pill bg-success px-4 py-2 fs-6 shadow-sm">
                                            @item.TotalUnitSold sản phẩm
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-danger shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> Đã có lỗi xảy ra khi tải dữ liệu báo cáo.
        </div>
    }
</div>

<style>
    .text-black {
        color: #000000 !important;
    }
    
    /* Tiêu đề bảng chữ trắng cỡ lớn */
    .table thead th {
        color: #ffffff !important;
        font-weight: 700;
        vertical-align: middle;
    }

    .table tbody tr:hover {
        background-color: #f8faff;
        transition: 0.2s;
    }

    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }
</style>