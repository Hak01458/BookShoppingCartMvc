@page
@model IndexModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h3 class="mb-3">@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-8 col-lg-6">
        <form id="profile-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            
            <div class="form-floating mb-3">
                <input asp-for="Username" class="form-control" placeholder="Tên đăng nhập của bạn." disabled />
                <label asp-for="Username" class="form-label">Tên đăng nhập</label>
            </div>
            
            <div class="form-floating mb-3">
                <input asp-for="Input.FullName" class="form-control" placeholder="Nhập họ và tên đầy đủ" />
                <label asp-for="Input.FullName" class="form-label">Họ và tên</label>
                <span asp-validation-for="Input.FullName" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Số điện thoại liên hệ" />
                <label asp-for="Input.PhoneNumber" class="form-label">Số điện thoại</label>
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
            </div>
            
            <div class="form-floating mb-3">
                <input asp-for="Input.Address" class="form-control" placeholder="Địa chỉ thường trú" />
                <label asp-for="Input.Address" class="form-label">Địa chỉ</label>
                <span asp-validation-for="Input.Address" class="text-danger"></span>
            </div>
            
            <div class="form-floating mb-3">
                <input asp-for="Input.DateOfBirth" type="date" class="form-control" />
                <label asp-for="Input.DateOfBirth" class="form-label">Ngày sinh</label>
                <span asp-validation-for="Input.DateOfBirth" class="text-danger"></span>
            </div>
            
            <button id="update-profile-button" type="submit" class="w-100 btn btn-lg btn-primary shadow-sm">Lưu thay đổi</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}