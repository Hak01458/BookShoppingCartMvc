@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Xác nhận gửi email";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-1 border-primary border-opacity-25">
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <i class="bi bi-envelope-check-fill text-success" style="font-size: 4.5rem;"></i>
                    </div>
                    <h2 class="text-primary fw-bold mb-3">@ViewData["Title"]</h2>
                    <p class="text-dark fs-5">
                        Yêu cầu đặt lại mật khẩu đã được gửi!
                    </p>
                    <p class="text-muted">
                        Vui lòng kiểm tra hộp thư đến trong email của bạn để thực hiện các bước tiếp theo.
                    </p>
                    
                    <hr class="my-4 border-primary border-opacity-10" />
                    
                    <div class="bg-light p-3 rounded-3 mb-4">
                        <p class="small text-secondary mb-0">
                            <i class="bi bi-info-circle me-1"></i>
                            Nếu không nhận được email, hãy kiểm tra thư mục <strong>Spam</strong> hoặc <strong>Thư rác</strong>.
                        </p>
                    </div>

                    <div class="d-grid shadow-sm">
                        <a asp-page="./Login" class="btn btn-primary btn-lg fw-bold">
                            Quay lại Đăng nhập
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>