@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu?";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-1">
                <div class="card-body p-5">
                    <h2 class="text-center mb-3 text-primary">@ViewData["Title"]</h2>
                    <p class="text-center text-muted mb-4 small">Nhập email của bạn để nhận liên kết khôi phục mật khẩu.</p>
                    
                    <section>
                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                            
                            <div class="form-floating mb-4">
                                <input asp-for="Input.Email" class="form-control border-primary border-opacity-25" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                                <label asp-for="Input.Email" class="form-label">Địa chỉ Email</label>
                                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>
                            
                            <button type="submit" class="w-100 btn btn-lg btn-primary shadow-sm mb-3">Gửi yêu cầu đặt lại</button>
                            
                            <div class="text-center mt-3">
                                <a asp-page="./Login" class="text-decoration-none small">
                                    <i class="bi bi-arrow-left"></i> Quay lại đăng nhập
                                </a>
                            </div>
                        </form>
                    </section>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}